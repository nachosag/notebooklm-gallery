{
  "private": true,
  "name": "notebooklm-gallery",
  "packageManager": "pnpm@11.2.2",

  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "deploy:backend": "pnpm --filter notebooklm-gallery-api run deploy",
    "deploy:frontend": "wrangler pages deploy frontend/ --project-name=notebooklm-gallery",
    "deploy": "pnpm run deploy:backend && pnpm run deploy:frontend"
  }
}
